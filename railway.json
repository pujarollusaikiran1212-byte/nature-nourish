{
    "$schema": "https://railway.app/schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd backend && npm install --omit=dev",
        "startCommand": "cd backend && node server.js"
    },
    "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}