{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "backend/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "backend/admin.html",
            "use": "@vercel/static"
        },
        {
            "src": "backend/customer-portal.html",
            "use": "@vercel/static"
        },
        {
            "src": "backend/style.css",
            "use": "@vercel/static"
        },
        {
            "src": "backend/script.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "backend/server.js"
        },
        {
            "src": "/admin",
            "dest": "backend/admin.html"
        },
        {
            "src": "/customer-portal",
            "dest": "backend/customer-portal.html"
        },
        {
            "src": "/(.*)",
            "dest": "backend/index.html"
        }
    ]
}